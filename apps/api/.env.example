# Copy to .env and fill in. Never commit real secrets.
LANDINGAI_API_KEY=
LANDINGAI_BASE_URL=https://api.va.landing.ai
LANDINGAI_PARSE_MODEL=dpt-2
LANDINGAI_EXTRACT_MODEL=extract-latest
CORS_ORIGIN=http://localhost:5173
JOB_ROOT=data/jobs
FORMS_DIR=assets/forms
FORMS_DOWNLOAD_ENABLED=true
JOBS_MAX_COUNT=200
JOB_TTL_SECONDS=86400
UPLOAD_RATE_LIMIT_PER_MINUTE=20
